---
import { FAMILY_BRANDS } from '../lib/model-labels';

interface Props {
  family: string;
  count?: number;
  active?: boolean;
  interactive?: boolean;
  countLabel?: string;
  size?: 'sm' | 'md';
}

const { family, count, active = false, interactive = true, countLabel, size = 'md' } = Astro.props;
const brand = FAMILY_BRANDS[family] ?? { letter: family.slice(0, 1).toUpperCase(), bg: '#94a3b8', fg: '#ffffff' };

const iconSize = size === 'sm' ? 'w-6 h-6 text-[11px]' : 'w-8 h-8 text-[13px]';
const padding = size === 'sm' ? 'px-2.5 py-1.5' : 'px-3 py-2';
const labelSize = size === 'sm' ? 'text-[13px]' : 'text-[14px]';
---

<span
  class:list={[
    'inline-flex items-center gap-2 rounded-xl bg-white transition-all',
    padding,
    interactive ? 'cursor-pointer' : '',
    active
      ? 'border-2 border-[var(--color-accent)] shadow-[0_2px_8px_rgba(204,120,92,0.12)]'
      : 'border border-[var(--color-line)] hover:border-[var(--color-accent)]/60',
  ]}
>
  <span
    class:list={[iconSize, 'rounded-md flex items-center justify-center font-bold shrink-0']}
    style={`background-color: ${brand.bg}; color: ${brand.fg};`}
  >{brand.letter}</span>
  <span class:list={[labelSize, 'font-semibold text-[var(--color-fg)]']}>{family}</span>
  {typeof count === 'number' && (
    <span class="text-[11px] font-medium text-[var(--color-ok)] bg-[color-mix(in_srgb,var(--color-ok)_14%,white)] px-2 py-0.5 rounded-md">
      {countLabel ?? `${count}`}
    </span>
  )}
</span>
