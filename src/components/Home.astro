---
import { getCollection, type CollectionEntry } from 'astro:content';
import StationCard from './StationCard.astro';
import FamilyBadge from './FamilyBadge.astro';
import { t, type Lang, formatSupportedCount } from '../lib/i18n';
import { buildModelIndex } from '../lib/model-labels';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const ui = t(lang);

const stations: CollectionEntry<'stations'>[] = await getCollection('stations');

stations.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return a.data.name.localeCompare(b.data.name);
});

const modelIndex = buildModelIndex(stations);
---

<section class="pt-6 sm:pt-8 pb-4 sm:pb-6 max-w-3xl">
  <h1 class="text-[22px] sm:text-[28px] font-extrabold tracking-tight leading-[1.2] text-[var(--color-fg)]">
    {ui.hero_q_pre}<span class="text-[var(--color-accent)] whitespace-nowrap">{ui.hero_q_emph}</span>{ui.hero_q_post}
  </h1>
</section>

<section class="mb-8">
  <div class="flex items-baseline gap-3 mb-3">
    <span class="text-[13px] text-[var(--color-fg-mute)] font-medium">{ui.filter_label}</span>
  </div>
  <div class="flex flex-wrap gap-2.5 items-center">
    <button data-filter="all" class="filter-btn inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-[var(--color-accent)] text-white border-2 border-[var(--color-accent)] transition-all">
      <span class="text-[14px] font-bold">{ui.filter_all}</span>
      <span class="text-[11px] font-medium text-white/80 bg-white/15 px-2 py-0.5 rounded-md">{stations.length}</span>
    </button>
    {modelIndex.map(({ label, count }) => (
      <button
        data-filter={label}
        class="filter-btn family-btn"
      >
        <FamilyBadge family={label} count={count} countLabel={formatSupportedCount(lang, count)} interactive={true} />
      </button>
    ))}
  </div>
</section>

<section
  id="grid"
  class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
>
  {stations.map(station => <StationCard station={station} lang={lang} />)}
</section>

<p id="empty" class="text-center text-[var(--color-fg-mute)] py-12 hidden">{ui.empty}</p>

<style>
  .family-btn {
    appearance: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .family-btn[data-active="true"] :global(.inline-flex) {
    border-color: var(--color-accent) !important;
    border-width: 2px !important;
    box-shadow: 0 2px 12px rgba(204, 120, 92, 0.18);
  }
</style>

<script>
  const allBtn = document.querySelector<HTMLButtonElement>('.filter-btn[data-filter="all"]');
  const familyBtns = document.querySelectorAll<HTMLButtonElement>('.family-btn');
  const cards = document.querySelectorAll<HTMLElement>('#grid > article');
  const empty = document.getElementById('empty');

  function apply(filter: string) {
    let visible = 0;
    cards.forEach(card => {
      const models = (card.dataset.models || '').split('|');
      const show = filter === 'all' || models.includes(filter);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (empty) empty.classList.toggle('hidden', visible > 0);
  }

  function setActive(active: HTMLButtonElement) {
    if (allBtn) {
      const isAll = active === allBtn;
      allBtn.classList.toggle('bg-[var(--color-accent)]', isAll);
      allBtn.classList.toggle('text-white', isAll);
      allBtn.classList.toggle('bg-white', !isAll);
      allBtn.classList.toggle('text-[var(--color-fg)]', !isAll);
    }
    familyBtns.forEach(b => b.dataset.active = b === active ? 'true' : 'false');
  }

  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      setActive(btn);
      apply(btn.dataset.filter!);
    });
  });
</script>
