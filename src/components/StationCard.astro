---
import type { CollectionEntry } from 'astro:content';
import { t, type Lang, localizedPath, pickName, pickShort, pickPriceNote, pickPromo, pickPrices } from '../lib/i18n';
import { stationModelLabels, FAMILY_BRANDS } from '../lib/model-labels';

interface Props {
  station: CollectionEntry<'stations'>;
  lang: Lang;
}

const { station, lang } = Astro.props;
const d = station.data;
const ui = t(lang);

const statusText: Record<typeof d.status, string> = {
  active: ui.status_active,
  unstable: ui.status_unstable,
  down: ui.status_down,
};
const statusColor: Record<typeof d.status, string> = {
  active: 'text-[var(--color-ok)]',
  unstable: 'text-[var(--color-warn)]',
  down: 'text-[var(--color-err)]',
};
const statusDot: Record<typeof d.status, string> = {
  active: 'bg-[var(--color-ok)]',
  unstable: 'bg-[var(--color-warn)]',
  down: 'bg-[var(--color-err)]',
};
const billingLabel: Record<typeof d.billing, string> = {
  payg: ui.billing_payg,
  subscription: ui.billing_subscription,
  hybrid: ui.billing_hybrid,
};

const name = pickName(d, lang);
const short = pickShort(d, lang);
const priceNote = pickPriceNote(d, lang);
const promo = pickPromo(d, lang);
const prices = pickPrices(d, lang) ?? {};

const ctaHref = d.affiliate ?? d.url;
const detailPath = localizedPath(lang, `/s/${station.id}/`);
const host = (() => { try { return new URL(d.url).host; } catch { return d.url; } })();
const modelLabels = stationModelLabels(d.models);
---

<article
  class="group relative bg-[var(--color-bg-card)] border border-[var(--color-line)] hover:border-[var(--color-accent)] transition-colors p-6 flex flex-col gap-4"
  data-models={modelLabels.join('|')}
  data-name={d.name}
>
  <header class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="text-[20px] font-extrabold tracking-tight text-[var(--color-fg)] leading-snug">
        <a href={detailPath} class="hover:text-[var(--color-accent)] transition-colors">{name}</a>
      </h3>
      <div class="text-[12px] text-[var(--color-fg-mute)] mt-1 font-mono truncate">{host}</div>
    </div>
    <div class="shrink-0 flex items-center gap-1.5 text-[12px] font-medium">
      <span class={`inline-block w-1.5 h-1.5 rounded-full ${statusDot[d.status]}`}></span>
      <span class={statusColor[d.status]}>{statusText[d.status]}</span>
    </div>
  </header>

  {short && <p class="text-[14px] text-[var(--color-fg-dim)] leading-relaxed line-clamp-3">{short}</p>}

  {promo && (
    <div class="text-[14px] font-bold text-[var(--color-accent)] leading-snug">
      {promo}
    </div>
  )}

  {modelLabels.length > 0 && (
    <div class="border-t border-[var(--color-line-soft)] pt-3 -mb-1">
      <div class="flex items-baseline justify-between mb-2">
        <span class="text-[11px] uppercase tracking-wider font-bold text-[var(--color-fg-mute)]">{ui.card_prices_label}</span>
        <span class="text-[11px] text-[var(--color-fg-mute)]">{billingLabel[d.billing]}</span>
      </div>
      <ul class="space-y-1.5">
        {modelLabels.map(family => {
          const brand = FAMILY_BRANDS[family];
          const priceStr = prices[family] ?? ui.price_unknown;
          return (
            <li class="flex items-center gap-2 text-[13px]">
              <span
                class="w-5 h-5 rounded-md flex items-center justify-center font-bold text-[10px] shrink-0"
                style={`background-color: ${brand.bg}; color: ${brand.fg};`}
              >{brand.letter}</span>
              <span class="font-semibold text-[var(--color-fg)] w-14 shrink-0">{family}</span>
              <span class="text-[var(--color-fg-dim)] truncate text-[12px]">{priceStr}</span>
            </li>
          );
        })}
      </ul>
    </div>
  )}

  {d.since && (
    <div class="text-[12px] text-[var(--color-fg-mute)]">
      {ui.card_since} {d.since}
    </div>
  )}

  <div class="mt-auto pt-3 flex items-center justify-between border-t border-[var(--color-line-soft)]">
    <a href={detailPath} class="text-[13px] text-[var(--color-fg-mute)] hover:text-[var(--color-fg)] font-medium">{ui.card_detail}</a>
    <a
      href={ctaHref}
      target="_blank"
      rel="noopener nofollow"
      class="text-[13px] font-bold text-[var(--color-accent)] hover:text-[var(--color-accent-deep)] transition-colors"
    >
      {ui.card_register}
    </a>
  </div>
</article>
