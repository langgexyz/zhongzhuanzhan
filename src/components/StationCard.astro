---
import type { CollectionEntry } from 'astro:content';
import { t, type Lang, pickName, pickPromo } from '../lib/i18n';
import { stationModelLabels } from '../lib/model-labels';

interface Props {
  station: CollectionEntry<'stations'>;
  lang: Lang;
}

const { station, lang } = Astro.props;
const d = station.data;
const ui = t(lang);

const billingLabel: Record<typeof d.billing, string> = {
  payg: ui.billing_payg,
  subscription: ui.billing_subscription,
  hybrid: ui.billing_hybrid,
};

const name = pickName(d, lang);
const promo = pickPromo(d, lang);

const ctaHref = d.affiliate ?? d.url;
const modelLabels = stationModelLabels(d.models);
const modelsCount = d.models.length;

function pickFlagshipModels(models: string[]): string[] {
  const orderedFamilies: Array<{ key: string; test: (m: string) => boolean }> = [
    { key: 'claude', test: m => m.toLowerCase().startsWith('claude') },
    { key: 'gpt', test: m => /^(gpt|openai\/|o\d)/i.test(m) || m.toLowerCase().includes('codex') },
    { key: 'gemini', test: m => m.toLowerCase().startsWith('gemini') },
  ];
  const picks: string[] = [];
  for (const { test } of orderedFamilies) {
    const match = models.find(test);
    if (match) picks.push(match);
  }
  return picks;
}
const flagshipModels = pickFlagshipModels(d.models);

const CLIENT_TAG_LABELS: Record<string, string> = {
  'claude-code': 'Claude Code',
  'codex-cli': 'Codex CLI',
  'cursor': 'Cursor',
  'cherry-studio': 'Cherry Studio',
  'lobe-chat': 'Lobe Chat',
  'cc-switch': 'CC Switch',
  'aionui': 'AionUI',
};
const clientTags = d.tags
  .filter(t => t in CLIENT_TAG_LABELS)
  .map(t => CLIENT_TAG_LABELS[t]);
---

<article
  class="group relative bg-[var(--color-bg-card)] border border-[var(--color-line)] hover:border-[var(--color-accent)] transition-colors flex flex-col"
  data-models={modelLabels.join('|')}
  data-name={d.name}
>
  <a
    href={ctaHref}
    target="_blank"
    rel="noopener nofollow"
    class="flex flex-col gap-3 p-5 flex-1 no-underline"
  >
    <header class="min-w-0">
      <h3 class="text-[18px] font-extrabold tracking-tight text-[var(--color-fg)] leading-snug group-hover:text-[var(--color-accent)] transition-colors">
        {name}
      </h3>
    </header>

    {promo && (
      <div class="text-[13px] font-bold text-[var(--color-accent)] leading-snug">
        {promo}
      </div>
    )}

    <div class="flex flex-wrap items-center gap-1.5 text-[11px] font-medium">
      <span class="inline-block px-2 py-0.5 rounded bg-[var(--color-bg-elev)] text-[var(--color-fg-mute)] uppercase tracking-wider">
        {billingLabel[d.billing]}
      </span>
      {modelsCount > 0 && (
        <span class="inline-block px-2 py-0.5 rounded bg-[var(--color-bg-elev)] text-[var(--color-fg-mute)] tracking-wider">
          {modelsCount} {ui.card_models_count}
        </span>
      )}
    </div>

    {flagshipModels.length > 0 && (
      <div class="flex flex-wrap items-center gap-1.5 text-[11px] font-mono">
        {flagshipModels.map(m => (
          <span class="inline-block px-2 py-0.5 rounded border border-[var(--color-line)] text-[var(--color-fg-dim)]">
            {m}
          </span>
        ))}
      </div>
    )}

    {clientTags.length > 0 && (
      <div class="flex flex-wrap items-center gap-1.5 text-[11px] font-medium">
        {clientTags.map(c => (
          <span class="inline-block px-2 py-0.5 rounded bg-[var(--color-accent-soft)] text-[var(--color-accent-deep)]">
            {c}
          </span>
        ))}
      </div>
    )}

    <div class="mt-auto pt-2.5 flex items-center justify-end border-t border-[var(--color-line-soft)]">
      <span
        class="text-[13px] font-bold text-[var(--color-accent)] group-hover:text-[var(--color-accent-deep)] transition-colors"
      >
        {ui.card_register}
      </span>
    </div>
  </a>
</article>
