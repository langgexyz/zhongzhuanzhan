---
import '../styles/global.css';
import { t, type Lang, altLangPath, localizedPath } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  /** path WITHOUT the locale prefix, e.g. '/' or '/s/zhoupb/' */
  path: string;
  ogImage?: string;
  jsonLd?: object;
}

const { title, description, lang, path, ogImage, jsonLd } = Astro.props;
const ui = t(lang);

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? '';
const canonical = `${siteUrl}${localizedPath(lang, path)}`;
const alt = altLangPath(lang, path);
const altCanonical = `${siteUrl}${alt.href}`;
const htmlLang = lang === 'zh-CN' ? 'zh-CN' : 'en';

const QR_EXPIRY_ISO = '2026-05-28';
const expiryDate = new Date(QR_EXPIRY_ISO);
const expiryFormatted = lang === 'zh-CN'
  ? `${expiryDate.getMonth() + 1}月${expiryDate.getDate()}日`
  : expiryDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
const wechatExpiryText = ui.wechat_expiry.replace('{date}', expiryFormatted);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh-CN" href={`${siteUrl}${localizedPath('zh-CN', path)}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${localizedPath('en', path)}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${localizedPath('zh-CN', path)}`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'zh-CN' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'zh-CN' ? 'en_US' : 'zh_CN'} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="robots" content="index,follow" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-20 bg-[var(--color-bg)]/85 backdrop-blur-md border-b border-[var(--color-line)]/50">
      <div class="max-w-5xl mx-auto px-6 sm:px-8 py-4 sm:py-5 flex items-center justify-between">
        <a href={localizedPath(lang, '/')} class="flex flex-col items-start gap-0.5 leading-none">
          <span class="flex items-baseline gap-2">
            <span class="font-extrabold text-[18px] tracking-tight text-[var(--color-fg)]">{ui.brand_l}</span>
            <span class="font-extrabold text-[18px] tracking-tight text-[var(--color-accent)]">{ui.brand_r}</span>
          </span>
          <span class="text-[11px] font-mono text-[var(--color-fg-mute)]">zhongzhuanzhan.site</span>
        </a>
        <nav class="flex items-center gap-5 sm:gap-6 text-[14px] font-medium text-[var(--color-fg-dim)]">
          <div class="relative">
            <button
              id="wechat-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="wechat-popover"
              class="inline-flex items-center gap-1 hover:text-[var(--color-accent)] text-[var(--color-fg-mute)] cursor-pointer"
            >
              <span>{ui.nav_wechat_group}</span>
              <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
                <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div
              id="wechat-popover"
              role="dialog"
              aria-labelledby="wechat-popover-title"
              hidden
              class="absolute right-0 top-[calc(100%+10px)] w-80 max-w-[calc(100vw-2rem)] p-4 rounded-xl bg-[var(--color-bg)] border border-[var(--color-line)] shadow-lg z-30"
            >
              <div id="wechat-popover-title" class="text-[13px] font-semibold text-[var(--color-fg)] mb-2.5">
                {ui.wechat_title}
              </div>
              <img
                src="/wechat-qr.jpg"
                alt={ui.wechat_qr_alt}
                width="720"
                height="1008"
                class="block w-full h-auto rounded-md border border-[var(--color-line-soft)]"
                loading="lazy"
              />
              <div class="mt-2.5 text-[11px] text-[var(--color-fg-mute)] leading-relaxed">
                {wechatExpiryText}
              </div>
            </div>
          </div>
          <a href={alt.href} hreflang={alt.lang} class="hover:text-[var(--color-accent)] text-[var(--color-fg-mute)]">
            {ui.nav_lang_switch}
          </a>
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 sm:px-8 pb-20">
      <slot />
    </main>

    <script>
      const trigger = document.getElementById('wechat-trigger');
      const popover = document.getElementById('wechat-popover');
      if (trigger && popover) {
        const close = () => {
          popover.setAttribute('hidden', '');
          trigger.setAttribute('aria-expanded', 'false');
        };
        const open = () => {
          popover.removeAttribute('hidden');
          trigger.setAttribute('aria-expanded', 'true');
        };
        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          popover.hasAttribute('hidden') ? open() : close();
        });
        document.addEventListener('click', (e) => {
          const target = e.target as Node;
          if (!popover.contains(target) && !trigger.contains(target)) close();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') close();
        });
      }
    </script>

    <footer class="mt-24 border-t border-[var(--color-line)]">
      <div class="max-w-5xl mx-auto px-6 sm:px-8 py-6 text-[13px] text-[var(--color-fg-mute)] flex flex-col sm:flex-row gap-2 sm:justify-between">
        <span>{ui.footer_disclaimer}</span>
        <a href={alt.href} hreflang={alt.lang} class="hover:text-[var(--color-accent)]">{ui.nav_lang_switch}</a>
      </div>
    </footer>
  </body>
</html>
