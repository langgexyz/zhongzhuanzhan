---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Detail from '../../../components/Detail.astro';
import { t, pickName, pickShort } from '../../../lib/i18n';

export async function getStaticPaths() {
  const stations = await getCollection('stations');
  return stations.map(s => ({ params: { slug: s.id }, props: { station: s } }));
}

const lang = 'en' as const;
const ui = t(lang);
const { station } = Astro.props;
const d = station.data;

const name = pickName(d, lang);
const short = pickShort(d, lang) ?? '';
const path = `/s/${station.id}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name,
  description: short,
  url: d.url,
  inLanguage: 'en',
  ...(d.contact ? { contactPoint: { '@type': 'ContactPoint', contactType: 'customer service', description: d.contact } } : {}),
};
---

<Base
  title={`${name} ${ui.meta_title_suffix}`}
  description={short || `${name} — ${ui.site_tagline}`}
  lang={lang}
  path={path}
  jsonLd={jsonLd}
>
  <Detail station={station} lang={lang} />
</Base>
