---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Home from '../components/Home.astro';
import { t } from '../lib/i18n';

const lang = 'zh-CN' as const;
const ui = t(lang);
const stations = await getCollection('stations');

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? '';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: ui.meta_title_home,
  description: ui.meta_desc_home,
  url: `${siteUrl}/`,
  inLanguage: 'zh-CN',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: stations.length,
    itemListElement: stations.map((s, idx) => ({
      '@type': 'ListItem',
      position: idx + 1,
      url: `${siteUrl}/s/${s.id}/`,
      name: s.data.name,
    })),
  },
};
---

<Base
  title={ui.meta_title_home}
  description={ui.meta_desc_home}
  lang={lang}
  path="/"
  jsonLd={jsonLd}
>
  <Home lang={lang} />
</Base>
